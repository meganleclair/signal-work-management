# Anthropic API key for Triage Assist — get yours at https://console.anthropic.com
# Named SIGNAL_ANTHROPIC_KEY (not ANTHROPIC_API_KEY) to avoid conflict with
# Claude for Desktop, which injects ANTHROPIC_API_KEY as blank in spawned shells.
SIGNAL_ANTHROPIC_KEY=sk-ant-...

# Triage state is stored in the browser (localStorage) — no database required.
